# Definitive V27 build with Debug Wrapper
FROM node:20

WORKDIR /app

ENV NODE_ENV production
ENV HOSTNAME "0.0.0.0"
ENV PORT 3000

# Install
COPY package.json package-lock.json ./
RUN npm ci

# Build
COPY . .
RUN npm run build

EXPOSE 3000

# Wrapper to detect why it exits
ENTRYPOINT ["sh", "-c", "echo '--- V27 BOOTING ---' && (node node_modules/.bin/next start || (echo '--- V27 FATAL EXIT ---' && sleep 3600))"]
