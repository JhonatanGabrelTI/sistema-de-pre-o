# Definitive V27 build
FROM node:20

WORKDIR /app

ENV CACHE_BYPASS=v27
ENV NODE_ENV production
ENV HOSTNAME "0.0.0.0"
ENV PORT 3000

# Install
COPY package.json package-lock.json ./
RUN npm ci

# Build
COPY . .
RUN npm run build

EXPOSE 3000

# Direct execution bypasses any npm/sh wrapper issues
ENTRYPOINT ["node", "node_modules/.bin/next", "start"]
